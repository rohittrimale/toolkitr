# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create one at: https://github.com/settings/developers → "New OAuth App"
#   Homepage URL:       http://localhost:3000
#   Authorization URL:  http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Session Encryption (generate random 32-char secret) ────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your_random_32_character_secret_here

# ── Database URL ────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/toolkitr

# ── Application URL (change for production) ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Mainframe Connection Settings ───────────────────────────────────────────
# These are used by setup scripts and connection dialogs
# Update these with your actual mainframe connection details
MAINFRAME_HOST=your.mainframe.hostname
MAINFRAME_USER=your_mainframe_username
MAINFRAME_PASSWORD=your_mainframe_password
MAINFRAME_PDS_NAME=YOUR.PROGRAMS.COBOL

# ── AI Model Configuration (Optional) ────────────────────────────────────────
# For advanced configuration, set these if needed:
# CLAUDE_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

